{
  "name": "gamepilot",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "description": "AI-powered gameplay synthesis agent that turns ideas into playable 2D no-asset game prototypes.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "smoke": "tsx src/engine/engine.smoke.ts",
    "serve": "tsx server/index.ts",
    "start": "npm run build && npm run serve",
    "mcp": "tsx server/mcp-stdio.ts"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "puppeteer-core": "^25.1.0",
    "tsx": "^4.22.4",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@fastify/static": "^9.1.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fastify": "^5.8.5",
    "zod": "^4.4.3"
  }
}
