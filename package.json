    "typecheck": "tsc --noEmit",
    "smoke": "tsx src/engine/engine.smoke.ts"
  },
  "devDependencies": {
    "puppeteer-core": "^25.1.0",
    "tsx": "^4.22.4",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
